{
  "expo": {
    "name": "Connecta",
    
   "slug": "connecta-app",
    "version": "1.0.0",
    "sdkVersion": "54.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "notification": {
      "androidMode": "default",
      "androidCollapsedTitle": "Connecta",
      "color": "#1e5faf",
      "iosDisplayInForeground": true
    },
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.connecta.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.connecta.app",
      "googleServicesFile": "./google-services.json",
      "versionCode": 6,
      "permissions": [
        "NOTIFICATIONS",
        "USE_FULL_SCREEN_INTENT",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED",
        "INTERNET"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "@react-native-firebase/app",
      "expo-font",
      "expo-updates"
    ],
    "extra": {
      "eas": {
        "projectId": "7a372738-20fb-49d2-b7c1-cecbe68b1a06"
      }
    }
  }
}
